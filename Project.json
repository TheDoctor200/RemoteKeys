{
  "configs": {
    "Debug": "debug",
    "Release": "release"
  },
  "name": "RemoteKeys",
  "options": {
    "groupSortPosition": "bottom",
    "transitivelyLinkDependencies": false
  },
  "settings": {
    "CODE_SIGN_IDENTITY": "-"
  },
  "targets": {
    "RemoteKeys": {
      "deploymentTarget": {
        "iOS": "17.0"
      },
      "info": {
        "path": "App/Info.plist",
        "properties": {
          "CFBundleDisplayName": "RemoteKeys",
          "CFBundleShortVersionString": "1.0",
          "CFBundleVersion": "1",
          "ITSAppUsesNonExemptEncryption": false,
          "UILaunchScreen": {},
          "NSLocalNetworkUsageDescription": "RemoteKeys uses your local network to connect to and control your MacBook.",
          "UISupportedInterfaceOrientations": [
            "UIInterfaceOrientationPortrait",
            "UIInterfaceOrientationPortraitUpsideDown",
            "UIInterfaceOrientationLandscapeLeft",
            "UIInterfaceOrientationLandscapeRight"
          ]
        }
      },
      "supportedDestinations": ["iOS"],
      "settings": {
        "ASSETCATALOG_COMPILER_APPICON_NAME": "AppIcon",
        "ASSETCATALOG_COMPILER_GLOBAL_ACCENT_COLOR_NAME": "AccentColor",
        "CURRENT_PROJECT_VERSION": "1",
        "MARKETING_VERSION": "1.0",
        "PRODUCT_BUNDLE_IDENTIFIER": "app.bitrig.remotekeys.00cbeaa4-0b73-41ff-bfbb-3005cb2127f5",
        "PRODUCT_NAME": "$(TARGET_NAME)",
        "SWIFT_VERSION": "5.0",
        "TARGETED_DEVICE_FAMILY": "1,2"
      },
      "sources": [
        {
          "path": "App"
        }
      ],
      "type": "application"
    }
  }
}
